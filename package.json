    "cf:preview": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:deploy:test": "npm run cf:build:test && opennextjs-cloudflare deploy --env=test",
    "cf:sync-secrets": "node scripts/sync-cloudflare-secrets.mjs",
